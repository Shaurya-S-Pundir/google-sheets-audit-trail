# ============================================================
# .gitignore for Google Apps Script Projects
# ============================================================

# --- OS-generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editor & IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Node / clasp (Google Apps Script CLI) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/
package-lock.json

# --- clasp credentials (NEVER commit these) ---
.clasprc.json
.clasp.json

# --- Environment / secrets ---
.env
.env.*
*.pem
*.key
secrets.json

# --- Build artifacts ---
dist/
build/
out/

# --- Logs ---
*.log
logs/

# --- Temporary files ---
*.tmp
*.temp
